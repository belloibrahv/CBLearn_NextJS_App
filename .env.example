# Database Configuration
# For Docker/Production: Use PostgreSQL
DATABASE_URL=postgresql://cblearn:cblearn_password@postgres:5432/cblearn

# For Local Development (SQLite): Comment out DATABASE_URL above and uncomment below
# SQLITE_PATH=./data/cblearn.db

# JWT Secret - CHANGE THIS IN PRODUCTION
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_change_in_production

# Node Environment
NODE_ENV=production

# Server Port (optional, defaults to 3000)
PORT=3000
